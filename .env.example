# Network interface to monitor (use wired for full visibility)
# Common: enp1s0f0 (wired), wlp2s0 (wireless), eth0 (RPI5)
NETWORK_INTERFACE=enp1s0f0

# Secondary interface for dual-interface monitoring (optional)
# Activate with: docker compose --profile dual up -d
# Note: wireless interfaces don't support true promiscuous mode in managed mode
NETWORK_INTERFACE_2=wlp2s0

# Host directory for shared log volume (must exist before docker compose up)
# Run: sudo mkdir -p /var/log/ids && sudo chmod 777 /var/log/ids
LOG_DIR=/var/log/ids

# Docker image tags (pinned for reproducibility, both support amd64+arm64)
SURICATA_TAG=7.0.8
ZEEK_TAG=7.0.4

# Suricata HOME_NET — networks considered "internal"
HOME_NET=192.168.0.0/16

# --- Phase 2: Data Pipeline ---

# Vector.dev Docker image tag (multi-arch: amd64+arm64)
VECTOR_TAG=0.53.0-alpine

# DuckDB log retention in hours (events older than this are auto-purged)
DUCKDB_TTL_HOURS=24

# Hours to keep NDJSON staging files and rotated Zeek logs (DuckDB has the data for TTL_HOURS)
STAGING_RETENTION_HOURS=6

# Maximum DuckDB file size in MB — ingestion pauses if exceeded (purge/vacuum still run)
MAX_DB_SIZE_MB=4000

# Suricata eve.json rotation threshold in MB — rotated when file exceeds this size
MAX_EVE_SIZE_MB=200

# Maximum total size of Vector NDJSON staging files in MB — oldest deleted when exceeded
MAX_STAGING_SIZE_MB=1024

# Maximum total size of Zeek log directory in MB — oldest rotated logs deleted when exceeded
MAX_ZEEK_LOGS_SIZE_MB=1024

# --- Phase 2.5: Grafana Dashboards ---

# Grafana Docker image tag (Ubuntu variant required for DuckDB plugin)
GRAFANA_TAG=11.6.0-ubuntu

# Grafana web UI port
GRAFANA_PORT=3000

# --- Phase 3: Agentic Intelligence ---

# Ollama model for chat (qwen3.5:2b for laptop/RPI5 — better than qwen2.5:3b, 262K ctx)
OLLAMA_MODEL=qwen3.5:2b

# CPU threads Ollama may use per inference request.
# Default (unset) = all cores → 800% on 8-core laptop. 4 = half cores.
OLLAMA_NUM_THREAD=4

# Streamlit chat UI port
STREAMLIT_PORT=8501

# Apprise notification URLs (comma-separated, e.g., slack://token, mailto://user:pass@host)
APPRISE_URLS=

# --- Phase 3b: Agentic Alerts ---
# Gmail credentials are managed via Docker Secrets (not env vars).
# See secrets/README.md for setup instructions.

# --- Anomaly Detection Tuning ---
# Traffic spike: fire when 5min conns > SPIKE_RATIO x hourly average AND >= SPIKE_MIN_CONNS
SPIKE_RATIO=5.0
SPIKE_MIN_CONNS=1000
SPIKE_COOLDOWN_MIN=60

# Massive volume: alert when any device transfers > VOLUME_THRESHOLD_MB in 5 minutes
VOLUME_THRESHOLD_MB=500
VOLUME_COOLDOWN_MIN=60

# Suspicious countries: comma-separated ISO country codes (GeoIP watchlist)
SUSPICIOUS_COUNTRIES=CN,RU,KP,IR,BY
COUNTRY_COOLDOWN_MIN=60

# Per-device behavioral baseline: alert when device exceeds BEHAVIOR_RATIO x its own rolling average
BEHAVIOR_RATIO=10.0
BEHAVIOR_MIN_SAMPLES=3
BASELINE_EMA_ALPHA=0.3

# Destination fan-out: alert when device contacts FANOUT_RATIO x its normal unique dest IPs
FANOUT_RATIO=5.0
FANOUT_MIN_IPS=10

# --- Nmap Scanning ---

# Subnet for scheduled nmap scans (CIDR notation, RFC1918 only)
NMAP_SUBNET=192.168.2.0/24

# Hours between scheduled nmap scans (168 = weekly)
NMAP_SCAN_INTERVAL_HOURS=168

# --- Suricata Rule Updates ---

# Hours between automatic suricata-update runs (24 = daily)
RULE_UPDATE_INTERVAL_HOURS=24
