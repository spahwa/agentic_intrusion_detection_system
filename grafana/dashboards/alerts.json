    {
      "id": 1,
      "type": "stat",
      "title": "Total Alerts",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "uid": "duckdb-ids",
        "type": "motherduck-duckdb-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT count(*) as value FROM events WHERE source_tool='suricata' AND json_extract_string(raw, '$.event_type')='alert' AND $__timeFilter(timestamp)",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
