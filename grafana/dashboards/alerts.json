          "rawSql": "SELECT timestamp, json_extract_string(raw, '$.alert.signature') as signature, CAST(json_extract(raw, '$.alert.severity') AS INTEGER) as severity, json_extract_string(raw, '$.src_ip') as src_ip, json_extract_string(raw, '$.dest_ip') as dest_ip, json_extract_string(raw, '$.dest_port') as dest_port, json_extract_string(raw, '$.proto') as proto FROM events WHERE source_tool='suricata' AND json_extract_string(raw, '$.event_type')='alert' AND $__timeFilter(timestamp) ORDER BY timestamp DESC LIMIT 50",
