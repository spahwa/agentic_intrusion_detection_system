{
  "uid": "ids-dns",
  "title": "DNS Analysis",
  "tags": ["ids"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total DNS Queries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "uid": "duckdb-ids",
        "type": "motherduck-duckdb-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT count(*) as value FROM events WHERE ((source_tool='suricata' AND json_extract_string(raw, '$.event_type')='dns') OR (source_tool='zeek' AND log_type='dns')) AND $__timeFilter(timestamp)",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unique Domains",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "uid": "duckdb-ids",
        "type": "motherduck-duckdb-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT count(DISTINCT COALESCE(json_extract_string(raw, '$.dns.rrname'), json_extract_string(raw, '$.query'))) as value FROM events WHERE ((source_tool='suricata' AND json_extract_string(raw, '$.event_type')='dns') OR (source_tool='zeek' AND log_type='dns')) AND $__timeFilter(timestamp)",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "NXDOMAIN Count",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "uid": "duckdb-ids",
        "type": "motherduck-duckdb-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT count(*) as value FROM events WHERE source_tool='suricata' AND json_extract_string(raw, '$.event_type')='dns' AND json_extract_string(raw, '$.dns.rcode')='NXDOMAIN' AND $__timeFilter(timestamp)",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "DNS Queries Over Time",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 14,
        "h": 8
      },
      "datasource": {
        "uid": "duckdb-ids",
        "type": "motherduck-duckdb-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT time_bucket(INTERVAL '5 minutes', timestamp) as time, source_tool, count(*) as count FROM events WHERE ((source_tool='suricata' AND json_extract_string(raw, '$.event_type')='dns') OR (source_tool='zeek' AND log_type='dns')) AND $__timeFilter(timestamp) GROUP BY time, source_tool ORDER BY time",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "scaleDistribution": {
              "type": "linear"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      }
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Top 20 Queried Domains",
      "gridPos": {
        "x": 14,
        "y": 5,
        "w": 10,
        "h": 8
      },
      "datasource": {
        "uid": "duckdb-ids",
        "type": "motherduck-duckdb-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(json_extract_string(raw, '$.dns.rrname'), json_extract_string(raw, '$.query')) as domain, count(*) as queries FROM events WHERE ((source_tool='suricata' AND json_extract_string(raw, '$.event_type')='dns') OR (source_tool='zeek' AND log_type='dns')) AND $__timeFilter(timestamp) GROUP BY domain ORDER BY queries DESC LIMIT 20",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "DNS Query Types",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "duckdb-ids",
        "type": "motherduck-duckdb-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(json_extract_string(raw, '$.dns.rrtype'), json_extract_string(raw, '$.qtype_name')) as query_type, count(*) as count FROM events WHERE ((source_tool='suricata' AND json_extract_string(raw, '$.event_type')='dns') OR (source_tool='zeek' AND log_type='dns')) AND $__timeFilter(timestamp) GROUP BY query_type ORDER BY count DESC",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "count"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "count",
            "desc": true
          }
        ],
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": ""
        }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "NXDOMAIN Domains",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "duckdb-ids",
        "type": "motherduck-duckdb-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT json_extract_string(raw, '$.dns.rrname') as domain, json_extract_string(raw, '$.src_ip') as querier, count(*) as count FROM events WHERE source_tool='suricata' AND json_extract_string(raw, '$.event_type')='dns' AND json_extract_string(raw, '$.dns.rcode')='NXDOMAIN' AND $__timeFilter(timestamp) GROUP BY domain, querier ORDER BY count DESC LIMIT 20",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "count"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "count",
            "desc": true
          }
        ],
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": ""
        }
      }
    }
  ],
