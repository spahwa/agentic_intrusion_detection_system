        "type": "motherduck-duckdb-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT count(*) as value FROM events WHERE ((source_tool='suricata' AND json_extract_string(raw, '$.event_type')='tls') OR (source_tool='zeek' AND log_type='ssl')) AND $__timeFilter(timestamp)",
          "format": 0
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
