{
  "uid": "ids-threats",
  "title": "Threats & Correlation",
  "tags": ["ids"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Anomaly Count",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "uid": "duckdb-ids",
        "type": "motherduck-duckdb-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT count(*) as value FROM events WHERE source_tool='suricata' AND json_extract_string(raw, '$.event_type')='anomaly' AND $__timeFilter(timestamp)",
          "format": 0
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "TLS Events",
      "gridPos": {
